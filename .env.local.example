# ─── Firebase ────────────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate new private key (downloads a JSON file)

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Paste the private_key value from the JSON file.
# Keep the quotes and replace literal newlines with \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Firebase Storage bucket — found in Firebase Console → Storage
# Newer projects use the .firebasestorage.app format
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
